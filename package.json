{
  "name": "openvoicing",
  "private": true,
  "version": "0.0.1",
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @openvoicing/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "test:coverage": "pnpm -r exec vitest run --coverage --coverage.provider=v8 --coverage.reporter=text-summary",
    "e2e": "pnpm --filter @openvoicing/web e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^4.1.9"
  }
}
