{
  "name": "@openvoicing/bundle",
  "version": "0.0.1",
  "description": "The OpenVoicing bundle (.ovb) format: create, read, validate",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "ovb": "./bin/ovb.mjs"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json",
    "build": "tsc -p tsconfig.build.json && node -e \"require('fs').writeFileSync('dist/package.json', JSON.stringify({type:'commonjs'}))\""
  },
  "dependencies": {
    "@openvoicing/score-model": "workspace:*",
    "fflate": "^0.8.3"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
